# Brevo (email service) API key — get this from app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# The verified sender email and name
SENDER_EMAIL=sylvester76daniel@gmail.com
SENDER_NAME=Sylvester Daniel

# Your Brevo List ID (the number, e.g. 2)
BREVO_LIST_ID=2

# A long random secret string used to sign unsubscribe links.
UNSUBSCRIBE_SECRET=change_this_to_a_long_random_string

# reCAPTCHA v3 keys (spam protection) — get these free at
# https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Your live site URL (used in email links) — update once deployed
SITE_URL=https://sylvesterdaniel.netlify.app
