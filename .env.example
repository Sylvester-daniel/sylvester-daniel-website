# Brevo (email service) API key — get this from app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# The verified sender email and name
BREVO_SENDER_EMAIL=sylvester76daniel@gmail.com
BREVO_SENDER_NAME=Sylvester Daniel

# Your Brevo List ID
BREVO_LIST_ID=2

# A long random secret string used to sign unsubscribe links.
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_TOKEN_SECRET=change_this_to_a_long_random_string

# A long random secret used to protect internal endpoints
# (send-thank-you, send-campaign, admin export). Generate the same way.
INTERNAL_API_SECRET=change_this_to_a_long_random_string

# A long random secret used to protect the cron endpoints.
CRON_SECRET=change_this_to_a_long_random_string

# reCAPTCHA v3 keys (spam protection)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Your live site URL (used in email links) — update once deployed
SITE_URL=https://sylvesterdaniel.netlify.app
